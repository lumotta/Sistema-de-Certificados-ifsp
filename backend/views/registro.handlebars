<h2>Criar Nova Conta</h2>

{{#if erro}}
    <p style="color: red; font-weight: bold;">{{erro}}</p>
{{/if}}

{{#if confirmado}}
    <p style="color: green; font-weight: bold;">{{confirmado}}</p>
{{/if}}

<form action="/registro/confirmacao" method="POST"> 
    <div>
        <label for="nome">Nome Completo:</label>
        <input type="text" name="nome" id="nome" maxlength="255" required>
    </div>
    <br>
    <div>
        <label for="email">E-mail:</label>
        <input type="email" name="email" id="email" maxlength="255" required>
    </div>
    <br>
    <div>
        <label for="senha">Senha (Mínimo 8 caracteres):</label>
        <input type="password" name="senha" id="senha" minlength="8" maxlength="255" required>
    </div>
    <br>
    <div>
        <label for="senhaN">Confirme a Senha:</label>
        <input type="password" name="senhaN" id="senhaN" minlength="8" maxlength="255" required>
    </div>
    <br>
    <button type="submit">Enviar Registro</button>
</form>

<hr>
<a href="/login"><button type="button">Voltar para o Login</button></a>